# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Email toggle ──────────────────────────────────────────────────────
# Set to "true" to send emails via AWS SES; "false" to only log locally
MAIL_ENABLED=true

# ── AWS SES Configuration ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
AWS_REGION=us-east-1

# ── SES Email Configuration ───────────────────────────────────────────
SES_SENDER_EMAIL=alerts@your-domain.com
SES_RECIPIENT_EMAILS=admin@your-domain.com

# ── Alert JSON log (all alerts written here regardless of MAIL_ENABLED) ──
ALERT_JSON_PATH=/var/log/smart_monitor_alerts.json
